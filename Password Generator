    use_digits = get_yes_no("Include Numbers? (Y/N): ")
    use_symbols = get_yes_no("Include Special Characters? (Y/N): ")
    password = generate_password(length,use_upper,use_lower,use_digits,use_symbols)
    print("\n" + "=" * 50)
